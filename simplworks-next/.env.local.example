# SimplWorks Editorial V1 — Environment Variables Template
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. Never commit real credentials.
#
# V1 USAGE: Not required. Reach Me is a mailto link. Supabase + Resend are scaffolded
# for V2 (form-based Friction Audit intake). See Implementation Guide Stage 4B Phase 2.

# --- Supabase (server-side only — no NEXT_PUBLIC_ prefix) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Resend (for future form notifications) ---
RESEND_API_KEY=
